{
  "name": "portabot",
  "version": "1.0.0",
  "description": "Portable RAG Chatbot Agent - Embeddable AI chatbot with knowledge base",
  "private": true,
  "workspaces": [
    "backend",
    "dashboard"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:dashboard\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:dashboard": "cd dashboard && npm run dev",
    "build": "npm run build:dashboard && npm run build:widget",
    "build:dashboard": "cd dashboard && npm run build",
    "build:widget": "cd widget && npm run build",
    "start": "cd backend && npm start",
    "lint": "eslint .",
    "test": "npm run test --workspaces"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
